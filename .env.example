# Copy this file to .env for local development, and set the same variables
# in your host's dashboard (Render / Railway) for production.

# --- Cloud MySQL connection ---
DB_HOST=your-mysql-host
DB_PORT=3306
DB_USER=your-mysql-user
DB_PASSWORD=your-mysql-password
DB_NAME=attendance_system

# Set DB_SSL=true if your provider requires SSL (e.g. Aiven, PlanetScale).
# Optionally point DB_SSL_CA at a CA certificate file path.
DB_SSL=false
# DB_SSL_CA=/path/to/ca.pem

# --- Admin login ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# --- Flask ---
FLASK_DEBUG=false
